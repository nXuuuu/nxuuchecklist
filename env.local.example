# Environment Variables for nXuu Trading Journal
# IMPORTANT: Create a .env.local file in your project root
# and fill in your Supabase credentials
# NEVER commit .env.local to Git!

# Your Supabase Project URL (found in Supabase Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anon Key (found in Supabase Settings → API)
# Use the NEW key after revoking the old one
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_KEY_HERE
